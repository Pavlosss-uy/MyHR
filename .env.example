# ─── LLM & Speech ────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ─── Vector Store ─────────────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=myhr-index

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Path to your Firebase service account JSON (never commit the actual file)
GOOGLE_APPLICATION_CREDENTIALS=path/to/firebase-adminsdk.json

# ─── AWS S3 (audio storage) ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=myhr-audio

# ─── Server URLs (Task 3.3) ───────────────────────────────────────────────────
# Backend base URL — used for audio URLs returned in API responses
BASE_URL=http://localhost:8000
BASE_WS_URL=ws://localhost:8000

# Streamlit frontend API target (app.py)
API_URL=http://localhost:8000

# CORS — set to your deployed React frontend origin in production
FRONTEND_URL=http://localhost:8080

# ─── Experiment Tracking (Task 3.9) ───────────────────────────────────────────
# MLflow tracking server URI — omit to disable MLflow (TensorBoard still runs)
# Local:  mlflow server --host 0.0.0.0 --port 5000  →  http://localhost:5000
# MLFLOW_TRACKING_URI=http://localhost:5000
